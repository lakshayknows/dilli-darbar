// Prisma schema — Delhi Darbar
// Local dev uses SQLite (free, zero-setup). To move to Neon free Postgres for
// production, change `provider` to "postgresql" and point DATABASE_URL at Neon.

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

// ---- Auth.js (NextAuth) models ----

model User {
  id            String    @id @default(cuid())
  name          String?
  email         String    @unique
  emailVerified DateTime?
  image         String?
  passwordHash  String?
  phone         String?
  createdAt     DateTime  @default(now())

  accounts Account[]
  sessions Session[]
  orders   Order[]
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

// ---- Domain models ----
// NOTE: SQLite has no enum support; these use String with app-level validation
// ("CATERING" | "ORDER", "PENDING" | "CONFIRMED" | "CANCELLED").

model Lead {
  id        String   @id @default(cuid())
  type      String
  name      String
  phone     String
  email     String?
  // JSON-encoded details (event type, headcount, cart contents, etc.)
  payload   String
  createdAt DateTime @default(now())
}

model Order {
  id        String   @id @default(cuid())
  userId    String
  status    String   @default("PENDING")
  total     Int
  createdAt DateTime @default(now())

  user  User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  items OrderItem[]
}

model OrderItem {
  id       String @id @default(cuid())
  orderId  String
  itemId   String
  name     String
  price    Int
  quantity Int

  order Order @relation(fields: [orderId], references: [id], onDelete: Cascade)
}
